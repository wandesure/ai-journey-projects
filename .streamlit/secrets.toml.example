# Streamlit Secrets Configuration
# Copy this file to secrets.toml and update with real values
# For Streamlit Cloud: Add these values in the app settings

# Required: Your Anthropic API key
ANTHROPIC_API_KEY = "your-anthropic-api-key-here"

# Required: User credentials for streamlit-authenticator
# Generate password hashes using: python generate_password_hash.py
#
# Example passwords shown below (DO NOT use in production):
#   admin = admin123
#   client1 = client123
#   client2 = client123

[credentials.usernames.admin]
email = "admin@example.com"
name = "Admin User"
password = "$2b$12$sLAxnV6qTLnhAPy88lMVwOYShWbOg4I8a6bfCHmBwvdh5JFMkHZ5."

[credentials.usernames.client1]
email = "client1@company.com"
name = "Demo Client 1"
password = "$2b$12$85qzFkcO5r3J2wmDpvobd.10mChDKjTHK0WmTiBwd3F5g90b2U8ci"

[credentials.usernames.client2]
email = "client2@company.com"
name = "Demo Client 2"
password = "$2b$12$04YITd0QsCPzRwQ0nR.tROhTy8ZJu40fYmQdAT0yDEXGZZ5NKqk1K"
